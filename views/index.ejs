<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>First Watch</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="mono-numbers">

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="header-left-row">
      <span class="wordmark">First<span class="wordmark-dot">.</span>Watch</span>
      <span class="page-meta" id="page-date"></span>
      <span class="market-status" id="market-status" aria-live="polite"></span>
    </div>
    <nav class="header-nav">
      <a href="/watchlist">Watchlist</a>
      <a href="/ai/history">History</a>
    </nav>
  </div>

  <!-- MAIN LAYOUT -->
  <div class="layout" id="mainLayout">

    <!-- LEFT: Q&A + NEWS -->
    <div class="col-left">

      <!-- Ask First Watch -->
      <div class="qa-section">
        <div class="section-label">Ask First Watch</div>
        <form id="ask-form">
          <div class="qa-input-row">
            <input
              class="qa-input"
              id="ask-input"
              type="text"
              name="question"
              placeholder="Ask about current market conditions..."
              autocomplete="off"
            />
            <button class="qa-submit" type="submit">Ask</button>
          </div>
        </form>
        <div class="qa-response" id="qa-response" style="display:none">
          <p class="qa-answer" id="qa-answer"></p>
          <div class="qa-timestamp" id="qa-timestamp"></div>
        </div>
      </div>

      <!-- News Feed -->
      <div class="news-section">
        <div class="section-label" id="news-section-label">Market News</div>
        <div class="news-list" id="news-list">
          <p class="loading-msg">Loading headlines&hellip;</p>
        </div>
      </div>

    </div>

    <!-- RIGHT: PRICES + BRIEF -->
    <div class="col-right">

      <!-- Price Table -->
      <div>
        <div class="section-label">Watchlist</div>
        <div class="price-table" id="price-table">
          <p class="loading-msg">Loading prices&hellip;</p>
        </div>
      </div>

      <!-- Market Brief Card -->
      <div>
        <div class="section-label">Market Brief</div>
        <div class="brief-card">
          <div class="brief-card-text" id="brief-content">
            <% if (latestBrief) { %>
              <% var paras = latestBrief.content.split('\n\n').filter(function(p) { return p.trim(); }); %>
              <% if (paras.length > 1) { %>
                <% paras.forEach(function(para) { %>
                  <p><%= para.trim() %></p>
                <% }); %>
              <% } else { %>
                <% latestBrief.content.split('\n').filter(function(p) { return p.trim(); }).forEach(function(para) { %>
                  <p><%= para.trim() %></p>
                <% }); %>
              <% } %>
            <% } else { %>
              <p class="empty-msg">No brief generated yet.</p>
            <% } %>
          </div>
          <div class="brief-card-footer">
            <span class="brief-generated">
              <% if (latestBrief) { %>
                Generated <%= new Date(latestBrief.generatedAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
              <% } %>
            </span>
            <form action="/ai/generate" method="POST" style="margin:0">
              <button class="brief-regen" type="submit">&#x21BB; Regenerate</button>
            </form>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    if (!localStorage.getItem('fw_onboarded')) {
      window.location.replace('/onboarding');
    }

    function escapeHtml(str) {
      if (str == null || str === '') return '';
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function loadMarketStatus() {
      fetch('/api/market-status')
        .then(function(res) { return res.json(); })
        .then(function(s) {
          var el = document.getElementById('market-status');
          if (!el) return;
          el.textContent = s.label || '';
          el.className = 'market-status' + (s.isRegularOpen ? ' market-status-open' : '');
        })
        .catch(function() {
          var el = document.getElementById('market-status');
          if (el) el.textContent = '';
        });
    }

    // Set current date in header
    const now = new Date();
    document.getElementById('page-date').textContent =
      now.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' }).toUpperCase() +
      ' · ' +
      now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) + ' EST';

    // ── PRICES ──
    function formatPrice(p) {
      if (!p || p === 0) return '—';
      return '$' + p.toFixed(2);
    }

    function renderPrices(prices) {
      const container = document.getElementById('price-table');
      if (!prices || prices.length === 0) {
        container.innerHTML = '<p class="empty-msg">No tickers saved. <a href="/watchlist">Add some.</a></p>';
        return;
      }
      container.innerHTML = prices.map(function(p) {
        const up = (p.percentChange != null ? p.percentChange : 0) >= 0;
        const changeClass = up ? 'up' : 'down';
        const sign = up ? '+' : '';
        const arrow = up ? '&#x2191;' : '&#x2193;';
        const pct = p.percentChange != null ? p.percentChange.toFixed(2) : '0.00';
        const sub = [];
        if (p.companyName) {
          sub.push('<div class="price-meta">' + escapeHtml(p.companyName) + '</div>');
        }
        if (p.exchange || p.industry) {
          sub.push('<div class="price-meta-sub">' + escapeHtml([p.exchange, p.industry].filter(Boolean).join(' · ')) + '</div>');
        }
        if (p.marketCapLabel) {
          sub.push('<div class="price-meta-sub">' + escapeHtml(p.marketCapLabel) + ' mkt cap</div>');
        }
        if (p.nextEarningsDate) {
          sub.push('<div class="price-earnings">Next earnings · ' + escapeHtml(p.nextEarningsDate) + '</div>');
        }
        return '<div class="price-row">' +
          '<div class="price-col-main">' +
            '<div class="price-ticker">' + escapeHtml(p.symbol) + '</div>' +
            sub.join('') +
          '</div>' +
          '<div class="price-vals">' +
            '<div class="price-current">' + formatPrice(p.price) + '</div>' +
            '<div class="price-change ' + changeClass + '">' + sign + pct + '% ' + arrow + '</div>' +
          '</div>' +
        '</div>';
      }).join('');
    }

    function loadPrices() {
      fetch('/api/prices')
        .then(function(res) { return res.json(); })
        .then(function(prices) { renderPrices(prices); })
        .catch(function() {
          document.getElementById('price-table').innerHTML = '<p class="loading-msg">Failed to load prices.</p>';
        });
    }

    // ── NEWS ──
    function timeAgo(unixTs) {
      const diff = Math.floor(Date.now() / 1000 - unixTs);
      if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
      if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
      return Math.floor(diff / 86400) + 'd ago';
    }

    function loadNews() {
      const container = document.getElementById('news-list');
      const labelEl = document.getElementById('news-section-label');
      fetch('/api/news')
        .then(function(res) { return res.json(); })
        .then(function(payload) {
          if (payload.error && (!payload.items || payload.items.length === 0)) {
            container.innerHTML = '<p class="loading-msg">' + escapeHtml(payload.error) + '</p>';
            if (labelEl) labelEl.textContent = 'Market News';
            return;
          }
          var articles = Array.isArray(payload) ? payload : (payload.items || []);
          var feed = payload.feed;
          if (labelEl) {
            labelEl.textContent = feed === 'watchlist' ? 'Watchlist News' : 'Market News';
          }
          if (!articles || articles.length === 0) {
            container.innerHTML = '<p class="loading-msg">No headlines available.</p>';
            return;
          }
          container.innerHTML = articles.map(function(a) {
            const badgeClass = 'badge-' + (a.sentiment || 'neutral');
            return '<div class="news-item">' +
              '<div>' +
                '<a href="' + (a.url || '#') + '" target="_blank" rel="noopener" class="news-headline">' + escapeHtml(a.headline) + '</a>' +
                '<div class="news-meta">' +
                  '<span class="news-source">' + escapeHtml(a.source || '') + '</span>' +
                  '<span class="news-time">' + timeAgo(a.datetime) + '</span>' +
                '</div>' +
              '</div>' +
              '<div class="badge-col">' +
                '<span class="badge ' + badgeClass + '">' + escapeHtml(a.sentiment || 'neutral') + '</span>' +
                '<div class="conf-bar"><div class="conf-bar-fill conf-bar-' + (a.sentiment || 'neutral') + '" style="width:' + (a.score !== undefined ? (Math.abs(a.score) * 100).toFixed(0) : '0') + '%"></div></div>' +
              '</div>' +
            '</div>';
          }).join('');
        })
        .catch(function() {
          container.innerHTML = '<p class="loading-msg">Failed to load headlines.</p>';
        });
    }

    loadPrices();
    loadNews();
    loadMarketStatus();
    setInterval(loadPrices, 60000);
    setInterval(loadMarketStatus, 300000);

    // ── ASK FORM ──
    document.getElementById('ask-form').addEventListener('submit', function(e) {
      e.preventDefault();
      const question = document.getElementById('ask-input').value.trim();
      if (!question) return;

      const responseDiv = document.getElementById('qa-response');
      const answerEl = document.getElementById('qa-answer');
      const tsEl = document.getElementById('qa-timestamp');
      responseDiv.style.display = 'block';
      answerEl.textContent = 'Thinking…';
      tsEl.textContent = '';

      fetch('/ai/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question: question })
      })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          answerEl.textContent = data.answer;
          tsEl.textContent = 'Answered · ' + new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        })
        .catch(function() {
          answerEl.textContent = 'Error. Please try again.';
        });
    });
  </script>

</body>
</html>
