<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Watchlist — First Watch</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

  <header class="header">
    <div class="header-left">
      <h1 class="logo"><a href="/">First Watch</a></h1>
    </div>
    <nav class="nav">
      <a href="/watchlist" class="active">Watchlist</a>
      <a href="/ai/history">Brief History</a>
    </nav>
  </header>

  <main class="page-content">
    <h2 class="section-title">Manage Watchlist</h2>

    <!-- ADD TICKER FORM -->
    <form action="/watchlist" method="POST" class="add-form">
      <input
        type="text"
        name="symbol"
        placeholder="Enter ticker symbol (e.g. AAPL)"
        required
        autocomplete="off"
      />
      <button type="submit">Add</button>
    </form>

    <p class="hint">
      Use standard ticker symbols: AAPL, TSLA, MSFT.<br />
      For commodities: GC=F (gold), CL=F (oil), SI=F (silver).
    </p>

    <!-- SAVED TICKERS -->
    <div class="ticker-list">
      <!-- TODO: loop through tickers array passed from server -->
      <% if (tickers.length === 0) { %>
        <p class="placeholder">No tickers saved yet. Add one above.</p>
      <% } else { %>
        <% tickers.forEach(ticker => { %>
          <div class="ticker-row">
            <span class="ticker-symbol"><%= ticker.symbol %></span>
            <form action="/watchlist/remove" method="POST">
              <input type="hidden" name="symbol" value="<%= ticker.symbol %>" />
              <button type="submit" class="remove-btn">Remove</button>
            </form>
          </div>
        <% }) %>
      <% } %>
    </div>
  </main>

</body>
</html>
