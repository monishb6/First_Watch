<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Watchlist — First Watch</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

  <div class="page-header">
    <div class="header-left-row">
      <a href="/" class="wordmark">First<span class="wordmark-dot">.</span>Watch</a>
    </div>
    <nav class="header-nav">
      <a href="/watchlist" class="active">Watchlist</a>
      <a href="/ai/history">History</a>
      <a href="/">Dashboard</a>
    </nav>
  </div>

  <main class="page-content">
    <div class="section-label" style="margin-bottom:20px">Manage Watchlist</div>

    <form action="/watchlist" method="POST" class="add-form" id="add-form">
      <input
        type="text"
        name="symbol"
        id="symbol-input"
        placeholder="Enter ticker symbol (e.g. AAPL)"
        required
        autocomplete="off"
        autocapitalize="characters"
      />
      <button type="submit" id="add-btn">Add</button>
    </form>
    <p class="ticker-validation-msg" id="validation-msg"></p>

    <p class="hint">
      Standard symbols: AAPL, TSLA, MSFT, NVDA, AMZN.<br />
      Commodities: GC=F (gold), CL=F (oil), SI=F (silver).
    </p>

    <div class="ticker-list">
      <% if (tickers.length === 0) { %>
        <p class="empty-msg">No tickers saved yet. Add one above.</p>
      <% } else { %>
        <% tickers.forEach(function(ticker) { %>
          <div class="ticker-row">
            <span class="ticker-symbol"><%= ticker.symbol %></span>
            <form action="/watchlist/remove" method="POST" style="margin:0">
              <input type="hidden" name="symbol" value="<%= ticker.symbol %>" />
              <button type="submit" class="remove-btn">Remove</button>
            </form>
          </div>
        <% }); %>
      <% } %>
    </div>
  </main>

  <script>
    var validatedSymbol = null;

    function setMsg(text, type) {
      var el = document.getElementById('validation-msg');
      el.className = 'ticker-validation-msg' + (type ? ' ticker-validation-' + type : '');
      el.textContent = text;
    }

    document.getElementById('symbol-input').addEventListener('input', function() {
      validatedSymbol = null;
      setMsg('', '');
    });

    document.getElementById('symbol-input').addEventListener('blur', function() {
      var raw = this.value.trim().toUpperCase();
      if (!raw) return;
      setMsg('Checking…', '');
      fetch('/api/validate-ticker?symbol=' + encodeURIComponent(raw))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.valid) {
            validatedSymbol = raw;
            setMsg(raw + ' ✓', 'ok');
          } else {
            validatedSymbol = null;
            setMsg('"' + raw + '" not found. Check the symbol.', 'err');
          }
        })
        .catch(function() { setMsg('', ''); });
    });

    document.getElementById('add-form').addEventListener('submit', function(e) {
      var raw = document.getElementById('symbol-input').value.trim().toUpperCase();
      if (!raw) return;
      if (validatedSymbol === raw) return; // already validated, let submit through

      e.preventDefault();
      var btn = document.getElementById('add-btn');
      btn.disabled = true;
      setMsg('Checking…', '');
      fetch('/api/validate-ticker?symbol=' + encodeURIComponent(raw))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.valid) {
            validatedSymbol = raw;
            document.getElementById('add-form').submit();
          } else {
            setMsg('"' + raw + '" not found. Check the symbol.', 'err');
            btn.disabled = false;
          }
        })
        .catch(function() {
          // network error — let it through
          document.getElementById('add-form').submit();
        });
    });
  </script>
</body>
</html>
