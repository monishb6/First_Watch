<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>First Watch — Get Started</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
  <style>
    .onboarding {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px 24px;
    }
    .onboarding-card {
      max-width: 480px;
      width: 100%;
    }
    .onboarding-wordmark {
      font-family: var(--mono);
      font-size: 16px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text);
      font-weight: 500;
      margin-bottom: 32px;
      display: block;
    }
    .onboarding-wordmark span {
      color: var(--accent);
    }
    .onboarding-headline {
      font-size: 28px;
      font-weight: 600;
      color: var(--text);
      line-height: 1.3;
      margin-bottom: 12px;
    }
    .onboarding-sub {
      font-size: 14px;
      color: var(--text-2);
      line-height: 1.6;
      margin-bottom: 36px;
    }
    .onboarding-features {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-bottom: 40px;
    }
    .onboarding-feature {
      display: flex;
      gap: 14px;
      align-items: flex-start;
    }
    .onboarding-feature-icon {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      background: var(--accent-dim);
      padding: 4px 8px;
      border-radius: var(--radius);
      white-space: nowrap;
      margin-top: 1px;
      flex-shrink: 0;
    }
    .onboarding-feature-text {
      font-size: 13px;
      color: var(--text-2);
      line-height: 1.5;
    }
    .onboarding-divider {
      height: 1px;
      background: var(--border);
      margin-bottom: 32px;
    }
    .onboarding-form-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-3);
      margin-bottom: 10px;
      display: block;
    }
    .onboarding-input-row {
      display: flex;
      gap: 8px;
      margin-bottom: 14px;
    }
    .onboarding-input {
      flex: 1;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      color: var(--text);
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 10px 14px;
      outline: none;
      transition: border-color 0.15s;
    }
    .onboarding-input::placeholder {
      text-transform: none;
      color: var(--text-3);
      font-family: var(--sans);
      letter-spacing: 0;
    }
    .onboarding-input:focus {
      border-color: rgba(var(--accent-rgb), 0.5);
    }
    .onboarding-btn {
      background: var(--accent);
      border: none;
      border-radius: var(--radius);
      color: #000;
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 10px 20px;
      cursor: pointer;
      transition: opacity 0.15s;
      white-space: nowrap;
    }
    .onboarding-btn:hover { opacity: 0.85; }
    .onboarding-btn:disabled { opacity: 0.5; cursor: default; }
    .onboarding-status {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text-3);
      min-height: 18px;
      margin-bottom: 20px;
    }
    .onboarding-status.ok { color: var(--green); }
    .onboarding-status.err { color: var(--red); }
    .onboarding-skip {
      font-size: 12px;
      color: var(--text-3);
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .onboarding-skip:hover { color: var(--text-2); opacity: 1; }
    @media (max-width: 480px) {
      .onboarding-headline { font-size: 22px; }
      .onboarding-input-row { flex-direction: column; }
      .onboarding-btn { width: 100%; }
    }
  </style>
</head>
<body>
  <div class="onboarding">
    <div class="onboarding-card">
      <span class="onboarding-wordmark">First<span>.</span>Watch</span>

      <div class="onboarding-headline">Market intelligence,<br>before the bell rings.</div>
      <p class="onboarding-sub">Live headlines scored for sentiment, prices refreshed every minute, and an AI you can ask anything about today's market.</p>

      <div class="onboarding-features">
        <div class="onboarding-feature">
          <span class="onboarding-feature-icon">News</span>
          <span class="onboarding-feature-text">Live headlines from Finnhub, each tagged Bullish / Neutral / Bearish by AI with a confidence score.</span>
        </div>
        <div class="onboarding-feature">
          <span class="onboarding-feature-icon">Prices</span>
          <span class="onboarding-feature-text">Real-time quotes for your saved tickers — price, % change, company details, next earnings date.</span>
        </div>
        <div class="onboarding-feature">
          <span class="onboarding-feature-icon">Ask AI</span>
          <span class="onboarding-feature-text">Ask anything about today's market. Answers are grounded in current headlines — no hallucination.</span>
        </div>
      </div>

      <div class="onboarding-divider"></div>

      <label class="onboarding-form-label">Add your first ticker to get started</label>
      <div class="onboarding-input-row">
        <input
          class="onboarding-input"
          id="ticker-input"
          type="text"
          placeholder="e.g. AAPL, NVDA, TSLA"
          maxlength="10"
          autocomplete="off"
          autocapitalize="characters"
        />
        <button class="onboarding-btn" id="add-btn">Add →</button>
      </div>
      <div class="onboarding-status" id="status"></div>
      <button class="onboarding-skip" id="skip-btn">Skip and go to dashboard</button>
    </div>
  </div>

  <script>
    function finish() {
      window.location.href = '/';
    }

    document.getElementById('skip-btn').addEventListener('click', finish);

    var validatedSymbol = null;

    function setStatus(text, type) {
      var el = document.getElementById('status');
      el.className = 'onboarding-status' + (type ? ' ' + type : '');
      el.textContent = text;
    }

    document.getElementById('ticker-input').addEventListener('input', function() {
      validatedSymbol = null;
      setStatus('', '');
    });

    document.getElementById('ticker-input').addEventListener('blur', function() {
      var raw = this.value.trim().toUpperCase();
      if (!raw) return;
      setStatus('Checking…', '');
      fetch('/api/validate-ticker?symbol=' + encodeURIComponent(raw))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.valid) {
            validatedSymbol = raw;
            setStatus(raw + ' ✓', 'ok');
          } else {
            validatedSymbol = null;
            setStatus('"' + raw + '" not found. Check the symbol.', 'err');
          }
        })
        .catch(function() { setStatus('', ''); });
    });

    document.getElementById('ticker-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') document.getElementById('add-btn').click();
    });

    document.getElementById('add-btn').addEventListener('click', function() {
      var raw = document.getElementById('ticker-input').value.trim().toUpperCase();
      if (!raw) return;

      var btn = document.getElementById('add-btn');

      function doAdd(symbol) {
        btn.disabled = true;
        setStatus('Adding…', '');
        fetch('/watchlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'symbol=' + encodeURIComponent(symbol),
          redirect: 'manual'
        })
          .then(function(res) {
            if (res.ok || res.status === 0 || res.type === 'opaqueredirect') {
              setStatus(symbol + ' added. Taking you to the dashboard…', 'ok');
              setTimeout(finish, 800);
            } else {
              throw new Error('Failed');
            }
          })
          .catch(function() {
            setStatus('Could not add ticker. Try again.', 'err');
            btn.disabled = false;
          });
      }

      if (validatedSymbol === raw) {
        doAdd(raw);
        return;
      }

      // not yet validated — validate first then add
      btn.disabled = true;
      setStatus('Checking…', '');
      fetch('/api/validate-ticker?symbol=' + encodeURIComponent(raw))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.valid) {
            validatedSymbol = raw;
            doAdd(raw);
          } else {
            setStatus('"' + raw + '" not found. Check the symbol.', 'err');
            btn.disabled = false;
          }
        })
        .catch(function() { doAdd(raw); }); // network failure → let it through
    });
  </script>
</body>
</html>
