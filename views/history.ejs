<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Brief History — First Watch</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

  <div class="page-header">
    <div class="header-left-row">
      <a href="/" class="wordmark">First<span class="wordmark-dot">.</span>Watch</a>
    </div>
    <nav class="header-nav">
      <a href="/watchlist">Watchlist</a>
      <a href="/ai/history" class="active">History</a>
      <a href="/">Dashboard</a>
      <span class="user-badge">@<%= username %></span>
      <form action="/logout" method="POST" style="margin:0">
        <button type="submit" class="logout-btn">Sign out</button>
      </form>
    </nav>
  </div>

  <main class="page-content page-content--full">
    <div class="section-label" style="margin-bottom:20px">AI Brief History</div>

    <% if (briefs.length === 0) { %>
      <p class="empty-msg">No briefs generated yet. Go to the <a href="/">dashboard</a> and click "Regenerate".</p>
    <% } else { %>
      <% briefs.forEach(function(brief) { %>
        <div class="brief-history-card">
          <div class="brief-date"><%= new Date(brief.generatedAt).toLocaleString() %></div>
          <div class="brief-body">
            <% var paras = brief.content.split('\n\n').filter(function(p) { return p.trim(); }); %>
            <% if (paras.length > 1) { %>
              <% paras.forEach(function(para) { %>
                <p><%= para.trim() %></p>
              <% }); %>
            <% } else { %>
              <% brief.content.split('\n').filter(function(p) { return p.trim(); }).forEach(function(para) { %>
                <p><%= para.trim() %></p>
              <% }); %>
            <% } %>
          </div>
        </div>
      <% }); %>
    <% } %>
  </main>

</body>
</html>
